{
  "name": "nudmcdg",
  "version": "1.0.0",
  "main": "index.js",
  "workspaces": [
    "packages/libraries",
    "example",
    "packages/modules/core",
    "packages/modules/common",
    "packages/modules/engagement",
    "packages/modules/sv"
  ],
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "run-s build start:dev",
    "start:dev": "run-p dev:libraries dev:common dev:core dev:engagement dev:sv dev:example",
    "dev:libraries": "cd packages/libraries && yarn start",
    "dev:components": "cd packages/react-components && yarn start",
    "dev:common": "cd packages/modules/common && yarn start",
    "dev:core": "cd packages/modules/core && yarn start",
    "dev:engagement": "cd packages/modules/engagement && yarn start",
    "dev:sv": "cd packages/modules/sv && yarn start",
    "dev:example": "cd example && yarn start",
    "build": "run-p build:**",
    "build:libraries": "cd packages/libraries && yarn build",
    "buildD:components": "cd packages/react-components && yarn build",
    "build:common": "cd packages/modules/common && yarn build",
    "build:core": "cd packages/modules/core && yarn build",
    "build:engagement": "cd packages/modules/engagement && yarn build",
    "build:sv": "cd packages/modules/sv && yarn build",
    "deploy:jenkins": "./scripts/jenkins.sh"
  },
  "devDependencies": {
    "husky": "7.0.4",
    "lint-staged": "12.3.7",
    "npm-run-all": "4.1.5",
    "prettier": "2.1.2"
  },
  "husky": {},
  "lint-staged": {
    "*.{js,css,md}": "prettier --write"
  },
  "dependencies": {
    "lodash": "4.17.21",
    "microbundle-crl": "^0.13.11"
  },
  "resolutions": {
    "node-sass": "npm:sass@^1.62.1"
  }
}
